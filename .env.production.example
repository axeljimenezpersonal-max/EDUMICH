# ─── Base de datos ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Sesiones ─────────────────────────────────────────────────────────────
SESSION_SECRET=cambia_esto_por_un_string_aleatorio_largo

# ─── Portal público ───────────────────────────────────────────────────────
PUBLIC_PORTAL_URL=https://edumich.up.railway.app
PORTAL_URL=https://edumich.up.railway.app

# ─── Email ────────────────────────────────────────────────────────────────
# Modos disponibles:
#   demo  → guarda en BD (tabla outbox), NO envía nada real  ← recomendado para demos
#   prod  → envía por Resend Y guarda en outbox para auditoría
#   dev   → solo imprime en consola, no guarda ni envía
EMAIL_MODE=demo

# Dirección remitente (requerida en modo prod)
EMAIL_FROM=noreply@edumich.up.railway.app

# API key de Resend (solo requerida si EMAIL_MODE=prod)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Copia institucional: todos los correos llevarán CC a esta dirección
# Si no se configura, no se incluye copia
INSTITUTIONAL_CC_EMAIL=notificaciones@michoacan.gob.mx

# Correo del admin para notificaciones de autoregistro
# Si no se define, usa INSTITUTIONAL_CC_EMAIL
# ADMIN_NOTIFICATION_EMAIL=admin@michoacan.gob.mx
