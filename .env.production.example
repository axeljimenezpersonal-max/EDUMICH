# ─── BASE DE DATOS ───
DATABASE_URL=postgresql://...neon.tech/dbname?sslmode=require

# ─── SERVIDOR ───
NODE_ENV=production
PORT=3001

# ─── SEGURIDAD ───
# Generar con: openssl rand -base64 48
SESSION_SECRET=<generar-secreto-seguro>

# ─── ARCHIVOS SUBIDOS ───
# Railway: usar /tmp (ephemeral) o montar un volumen persistente
STORAGE_DIR=/tmp/prepa-storage

# ─── PORTAL URL (para links en emails) ───
PUBLIC_PORTAL_URL=https://TU-APP.up.railway.app/login

# ─── EMAIL (Resend) ───
RESEND_API_KEY=re_xxxx
EMAIL_MODE=prod
EMAIL_FROM=Prepa Abierta Michoacán <noreply@resend.dev>

# ─── DEMO ───
IS_DEMO_DEPLOY=true
